# .env file for Alpamayo 1.5 Docker
# Copy this file and customize for your environment

# HuggingFace token (get from https://huggingface.co/settings/tokens)
# HF_TOKEN=your_token_here

# Model configuration
MODEL_NAME=nvidia/Alpamayo-1.5-10B
MODEL_CACHE_DIR=/root/.cache/huggingface/hub

# Data configuration  
DATASET_NAME=PhysicalAI/PhysicalAI-Autonomous-Vehicles
DATA_CACHE_DIR=/workspace/alpamayo/data

# Output configuration
OUTPUT_DIR=/workspace/alpamayo/outputs
CHECKPOINT_DIR=/workspace/alpamayo/checkpoints

# Training configuration for 7GB VRAM
# Adjust based on your GPU memory
MAX_BATCH_SIZE=1
GRADIENT_ACCUMULATION_STEPS=4
USE_QLORA=true
QUANTIZATION_BITS=4

# Memory optimization settings
USE_GRADIENT_CHECKPOINTING=true
ENABLE_CPU_OFFLOAD=false
